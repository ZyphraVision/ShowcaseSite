---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "ZyphraVision — Vision Redefined. AI-powered glasses for the visually impaired." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08080f" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-background text-text-primary font-body overflow-x-hidden">
    <slot />
  </body>
</html>
