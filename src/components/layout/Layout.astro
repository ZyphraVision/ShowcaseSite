---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from './Navbar';
import Footer from './Footer';
import WaitlistModal from '../shared/WaitlistModal';
---

<BaseLayout title={Astro.props.title} description={Astro.props.description}>
  <div class="flex flex-col min-h-screen relative z-10" id="app-root">
    <Navbar client:load />
    
    <main class="flex-1">
      <slot />
    </main>
    
    <Footer />
    <WaitlistModal client:idle />
  </div>
</BaseLayout>

<script>
  // Global waitlist modal state bridge
  let modalInstance: any = null;
  
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.querySelector('[data-waitlist-modal]');
    const triggers = document.querySelectorAll('[data-waitlist-trigger]');
    
    const openModal = () => {
      const event = new CustomEvent('waitlist:open');
      document.dispatchEvent(event);
    };
    
    triggers.forEach(t => t.addEventListener('click', openModal));
  });
</script>